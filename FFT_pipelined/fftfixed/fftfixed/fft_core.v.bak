// =============================================================================
//  8-point FFT Core  -  Fixed-Point  sQ(INT, FRAC_BITS)  format
//
//  FRAC_BITS = 2 throughout.  Integer bits grow by 1 per stage.
//
//  Stage | Format  | Total bits | Representation
//  ------+---------+------------+----------------------------
//    0   | sQ5.2   |     8      | Input  (1 sign + 5 int + 2 frac)
//    1   | sQ6.2   |     9      | After stage-1 butterfly
//    2   | sQ7.2   |    10      | After stage-2 butterfly
//    3   | sQ8.2   |    11      | Output (1 sign + 8 int + 2 frac)
//
//  Twiddle multiply (complex_twiddle_block):
//    Constant 181 is stored in Q(0,8). Product has FRAC+8 fractional bits;
//    right-shift of 8 restores exactly FRAC=2 fractional bits.
// =============================================================================
module fft_core(
    input clk, reset,
    input signed [63:0] in_real, in_img,   // 8 × sQ5.2  (8 bits each)
    input in_valid,

    output signed [87:0] out_real, out_img, // 8 × sQ8.2  (11 bits each)
    output reg out_valid
);

    localparam FRAC_BITS = 2; // fractional bits — constant across all stages

    // -------------------------------------------------------------------------
    //  Unpack 8 input samples  (sQ5.2, 8 bits each)
    // -------------------------------------------------------------------------
    wire signed [7:0] x0_real[7:0];
    wire signed [7:0] x0_img [7:0];

    assign {x0_real[7], x0_real[6], x0_real[5], x0_real[4],
            x0_real[3], x0_real[2], x0_real[1], x0_real[0]} = in_real;
    assign {x0_img[7],  x0_img[6],  x0_img[5],  x0_img[4],
            x0_img[3],  x0_img[2],  x0_img[1],  x0_img[0]}  = in_img;


    // =========================================================================
    //  Stage 1  —  no-twiddle butterfly  |  sQ5.2 (8b) → sQ6.2 (9b)
    //  Pairs: {0,4}, {2,6}, {1,5}, {3,7}
    // =========================================================================
    wire signed [8:0] s1_real[7:0];
    wire signed [8:0] s1_img [7:0];

    no_twiddle_block #(8) stg1_blk1(x0_real[0], x0_img[0], x0_real[4], x0_img[4],
                                     s1_real[0], s1_img[0], s1_real[1], s1_img[1]);
    no_twiddle_block #(8) stg1_blk2(x0_real[2], x0_img[2], x0_real[6], x0_img[6],
                                     s1_real[2], s1_img[2], s1_real[3], s1_img[3]);
    no_twiddle_block #(8) stg1_blk3(x0_real[1], x0_img[1], x0_real[5], x0_img[5],
                                     s1_real[4], s1_img[4], s1_real[5], s1_img[5]);
    no_twiddle_block #(8) stg1_blk4(x0_real[3], x0_img[3], x0_real[7], x0_img[7],
                                     s1_real[6], s1_img[6], s1_real[7], s1_img[7]);

    // --- Stage-1 pipeline registers (9-bit = sQ6.2) ---
    wire signed [8:0] s1_real_pr     [7:0];
    wire signed [8:0] s1_img_pr      [7:0];
    wire signed [8:0] s1_real_pr_wire[7:0];
    wire signed [8:0] s1_img_pr_wire [7:0];

    pipeline_regs #(9) pipeline_stg1 (clk, reset,
        {s1_real[7],    s1_real[6],    s1_real[5],    s1_real[4],
         s1_real[3],    s1_real[2],    s1_real[1],    s1_real[0]},
        {s1_img[7],     s1_img[6],     s1_img[5],     s1_img[4],
         s1_img[3],     s1_img[2],     s1_img[1],     s1_img[0]},
        {s1_real_pr[7], s1_real_pr[6], s1_real_pr[5], s1_real_pr[4],
         s1_real_pr[3], s1_real_pr[2], s1_real_pr[1], s1_real_pr[0]},
        {s1_img_pr[7],  s1_img_pr[6],  s1_img_pr[5],  s1_img_pr[4],
         s1_img_pr[3],  s1_img_pr[2],  s1_img_pr[1],  s1_img_pr[0]});

    assign {s1_real_pr_wire[7], s1_real_pr_wire[6], s1_real_pr_wire[5], s1_real_pr_wire[4],
            s1_real_pr_wire[3], s1_real_pr_wire[2], s1_real_pr_wire[1], s1_real_pr_wire[0]}
         = {s1_real_pr[7],      s1_real_pr[6],      s1_real_pr[5],      s1_real_pr[4],
            s1_real_pr[3],      s1_real_pr[2],      s1_real_pr[1],      s1_real_pr[0]};
    assign {s1_img_pr_wire[7],  s1_img_pr_wire[6],  s1_img_pr_wire[5],  s1_img_pr_wire[4],
            s1_img_pr_wire[3],  s1_img_pr_wire[2],  s1_img_pr_wire[1],  s1_img_pr_wire[0]}
         = {s1_img_pr[7],       s1_img_pr[6],       s1_img_pr[5],       s1_img_pr[4],
            s1_img_pr[3],       s1_img_pr[2],       s1_img_pr[1],       s1_img_pr[0]};


    // =========================================================================
    //  Stage 2  —  no-twiddle + simple-twiddle butterfly  |  sQ6.2 (9b) → sQ7.2 (10b)
    // =========================================================================
    wire signed [9:0] s2_real[7:0];
    wire signed [9:0] s2_img [7:0];

    no_twiddle_block     #(9) stg2_blk1(s1_real_pr_wire[0], s1_img_pr_wire[0],
                                         s1_real_pr_wire[2], s1_img_pr_wire[2],
                                         s2_real[0], s2_img[0], s2_real[2], s2_img[2]);
    simple_twiddle_block #(9) stg2_blk2(s1_real_pr_wire[1], s1_img_pr_wire[1],
                                         s1_real_pr_wire[3], s1_img_pr_wire[3],
                                         s2_real[1], s2_img[1], s2_real[3], s2_img[3]);
    no_twiddle_block     #(9) stg2_blk3(s1_real_pr_wire[4], s1_img_pr_wire[4],
                                         s1_real_pr_wire[6], s1_img_pr_wire[6],
                                         s2_real[4], s2_img[4], s2_real[6], s2_img[6]);
    simple_twiddle_block #(9) stg2_blk4(s1_real_pr_wire[5], s1_img_pr_wire[5],
                                         s1_real_pr_wire[7], s1_img_pr_wire[7],
                                         s2_real[5], s2_img[5], s2_real[7], s2_img[7]);

    // --- Stage-2 pipeline registers (10-bit = sQ7.2) ---
    wire signed [9:0] s2_real_pr     [7:0];
    wire signed [9:0] s2_img_pr      [7:0];
    wire signed [9:0] s2_real_pr_wire[7:0];
    wire signed [9:0] s2_img_pr_wire [7:0];

    pipeline_regs #(10) pipeline_stg2 (clk, reset,
        {s2_real[7],    s2_real[6],    s2_real[5],    s2_real[4],
         s2_real[3],    s2_real[2],    s2_real[1],    s2_real[0]},
        {s2_img[7],     s2_img[6],     s2_img[5],     s2_img[4],
         s2_img[3],     s2_img[2],     s2_img[1],     s2_img[0]},
        {s2_real_pr[7], s2_real_pr[6], s2_real_pr[5], s2_real_pr[4],
         s2_real_pr[3], s2_real_pr[2], s2_real_pr[1], s2_real_pr[0]},
        {s2_img_pr[7],  s2_img_pr[6],  s2_img_pr[5],  s2_img_pr[4],
         s2_img_pr[3],  s2_img_pr[2],  s2_img_pr[1],  s2_img_pr[0]});

    assign {s2_real_pr_wire[7], s2_real_pr_wire[6], s2_real_pr_wire[5], s2_real_pr_wire[4],
            s2_real_pr_wire[3], s2_real_pr_wire[2], s2_real_pr_wire[1], s2_real_pr_wire[0]}
         = {s2_real_pr[7],      s2_real_pr[6],      s2_real_pr[5],      s2_real_pr[4],
            s2_real_pr[3],      s2_real_pr[2],      s2_real_pr[1],      s2_real_pr[0]};
    assign {s2_img_pr_wire[7],  s2_img_pr_wire[6],  s2_img_pr_wire[5],  s2_img_pr_wire[4],
            s2_img_pr_wire[3],  s2_img_pr_wire[2],  s2_img_pr_wire[1],  s2_img_pr_wire[0]}
         = {s2_img_pr[7],       s2_img_pr[6],       s2_img_pr[5],       s2_img_pr[4],
            s2_img_pr[3],       s2_img_pr[2],       s2_img_pr[1],       s2_img_pr[0]};


    // =========================================================================
    //  Stage 3  —  mixed butterfly  |  sQ7.2 (10b) → sQ8.2 (11b)
    //    blk1: no-twiddle      (W8^0 = 1)
    //    blk2: complex-twiddle (W8^1,  op=0)
    //    blk3: simple-twiddle  (W8^2 = -j)
    //    blk4: complex-twiddle (W8^3,  op=1)
    // =========================================================================
    wire signed [10:0] x1_real[7:0];
    wire signed [10:0] x1_img [7:0];

    no_twiddle_block      #(10) stg3_blk1(s2_real_pr_wire[0], s2_img_pr_wire[0],
                                           s2_real_pr_wire[4], s2_img_pr_wire[4],
                                           x1_real[0], x1_img[0], x1_real[4], x1_img[4]);

    complex_twiddle_block #(10) stg3_blk2(s2_real_pr_wire[1], s2_img_pr_wire[1],
                                           s2_real_pr_wire[5], s2_img_pr_wire[5],
                                           1'b0,
                                           x1_real[1], x1_img[1], x1_real[5], x1_img[5]);

    simple_twiddle_block  #(10) stg3_blk3(s2_real_pr_wire[2], s2_img_pr_wire[2],
                                           s2_real_pr_wire[6], s2_img_pr_wire[6],
                                           x1_real[2], x1_img[2], x1_real[6], x1_img[6]);

    complex_twiddle_block #(10) stg3_blk4(s2_real_pr_wire[3], s2_img_pr_wire[3],
                                           s2_real_pr_wire[7], s2_img_pr_wire[7],
                                           1'b1,
                                           x1_real[3], x1_img[3], x1_real[7], x1_img[7]);

    // --- Stage-3 pipeline registers (11-bit = sQ8.2) ---
    wire signed [10:0] x1_real_pr     [7:0];
    wire signed [10:0] x1_img_pr      [7:0];
    wire signed [10:0] x1_real_pr_wire[7:0];
    wire signed [10:0] x1_img_pr_wire [7:0];

    pipeline_regs #(11) pipeline_stg3 (clk, reset,
        {x1_real[7],    x1_real[6],    x1_real[5],    x1_real[4],
         x1_real[3],    x1_real[2],    x1_real[1],    x1_real[0]},
        {x1_img[7],     x1_img[6],     x1_img[5],     x1_img[4],
         x1_img[3],     x1_img[2],     x1_img[1],     x1_img[0]},
        {x1_real_pr[7], x1_real_pr[6], x1_real_pr[5], x1_real_pr[4],
         x1_real_pr[3], x1_real_pr[2], x1_real_pr[1], x1_real_pr[0]},
        {x1_img_pr[7],  x1_img_pr[6],  x1_img_pr[5],  x1_img_pr[4],
         x1_img_pr[3],  x1_img_pr[2],  x1_img_pr[1],  x1_img_pr[0]});

    assign {x1_real_pr_wire[7], x1_real_pr_wire[6], x1_real_pr_wire[5], x1_real_pr_wire[4],
            x1_real_pr_wire[3], x1_real_pr_wire[2], x1_real_pr_wire[1], x1_real_pr_wire[0]}
         = {x1_real_pr[7],      x1_real_pr[6],      x1_real_pr[5],      x1_real_pr[4],
            x1_real_pr[3],      x1_real_pr[2],      x1_real_pr[1],      x1_real_pr[0]};
    assign {x1_img_pr_wire[7],  x1_img_pr_wire[6],  x1_img_pr_wire[5],  x1_img_pr_wire[4],
            x1_img_pr_wire[3],  x1_img_pr_wire[2],  x1_img_pr_wire[1],  x1_img_pr_wire[0]}
         = {x1_img_pr[7],       x1_img_pr[6],       x1_img_pr[5],       x1_img_pr[4],
            x1_img_pr[3],       x1_img_pr[2],       x1_img_pr[1],       x1_img_pr[0]};

    // -------------------------------------------------------------------------
    //  Pack 8 output samples  (sQ8.2, 11 bits each → 88 bits total)
    // -------------------------------------------------------------------------
    assign out_real = {x1_real_pr_wire[7], x1_real_pr_wire[6], x1_real_pr_wire[5], x1_real_pr_wire[4],
                       x1_real_pr_wire[3], x1_real_pr_wire[2], x1_real_pr_wire[1], x1_real_pr_wire[0]};
    assign out_img  = {x1_img_pr_wire[7],  x1_img_pr_wire[6],  x1_img_pr_wire[5],  x1_img_pr_wire[4],
                       x1_img_pr_wire[3],  x1_img_pr_wire[2],  x1_img_pr_wire[1],  x1_img_pr_wire[0]};

    // -------------------------------------------------------------------------
    //  Valid pipeline  (3 registers for 3 pipeline stages)
    // -------------------------------------------------------------------------
    reg v1, v2, v3;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            v1 <= 0; v2 <= 0; v3 <= 0; out_valid <= 0;
        end else begin
            v1       <= in_valid;
            v2       <= v1;
            v3       <= v2;
            out_valid <= v2;
        end
    end

    // -------------------------------------------------------------------------
    //  Optional: unpacked output buses for simulation inspection (sQ8.2)
    // -------------------------------------------------------------------------
    wire signed [10:0] out_real_split[7:0];
    wire signed [10:0] out_img_split [7:0];

    assign {out_real_split[7], out_real_split[6], out_real_split[5], out_real_split[4],
            out_real_split[3], out_real_split[2], out_real_split[1], out_real_split[0]} = out_real;
    assign {out_img_split[7],  out_img_split[6],  out_img_split[5],  out_img_split[4],
            out_img_split[3],  out_img_split[2],  out_img_split[1],  out_img_split[0]}  = out_img;

endmodule
