// Complex Twiddle Block  -  Fixed-Point  sQ(WIDTH-3, 2)
//
// Implements a radix-2 DIF butterfly with W8^1 (op=0) or W8^3 (op=1):
//   W8^1 = (1/√2)(1 - j)    W8^3 = (1/√2)(-1 - j)
//
// Twiddle constant 181  ≈  181/256 ≈ 0.707  stored in Q(0,8).
//
// Q-format scaling for the 0.707 multiply:
//   Input tw_real / tw_imag are sQ(WIDTH-2, 2)  →  FRAC = 2 fractional bits
//   Twiddle constant 181 is Q(0,8)               →  8 fractional bits
//   Raw product has FRAC + 8 = 10 fractional bits
//   Shift right 8 restores exactly FRAC = 2 fractional bits  ✓
//
// Bit-width growth:
//   Input  : WIDTH bits  (sQ(WIDTH-3, 2))
//   Output : WIDTH+1 bits (sQ(WIDTH-2, 2))  — same 1-bit growth as no/simple twiddle blocks

module complex_twiddle_block #(
    parameter WIDTH = 8
)(
    input  signed [WIDTH-1:0] a_real, a_img,
    input  signed [WIDTH-1:0] b_real, b_img,
    input  op,                              // 0 → W8^1 ,  1 → W8^3

    output signed [WIDTH:0] y0_real, y0_img,  // WIDTH+1 bits  sQ(WIDTH-2,2)
    output signed [WIDTH:0] y1_real, y1_img
);

    // =========================================================
    // Step 1: Sign-extend inputs to WIDTH+1 bits for safe sums
    // =========================================================
    wire signed [WIDTH:0] a_real_ext = a_real;
    wire signed [WIDTH:0] a_img_ext  = a_img;
    wire signed [WIDTH:0] b_real_ext = b_real;
    wire signed [WIDTH:0] b_img_ext  = b_img;

    // =========================================================
    // Step 2: Pre-add/sub  →  decomposes B · W8^k without division
    //   t1 = br + bi     t2 = bi - br
    // (WIDTH+1 bits — no overflow since inputs are bounded by FFT range)
    // =========================================================
    wire signed [WIDTH:0] t1 = b_real_ext + b_img_ext;
    wire signed [WIDTH:0] t2 = b_img_ext  - b_real_ext;

    // =========================================================
    // Step 3: Select twiddle components
    //   W8^1:  tw_real = +t1 ,  tw_imag = +t2
    //   W8^3:  tw_real = +t2 ,  tw_imag = -t1
    // =========================================================
    wire signed [WIDTH:0] tw_real = (op == 1'b0) ?  t1 :  t2;
    wire signed [WIDTH:0] tw_imag = (op == 1'b0) ?  t2 : -t1;

    // =========================================================
    // Step 4: Multiply by 181 (twiddle constant in Q(0,8) ≈ 0.707)
    //
    // Product width: (WIDTH+1) bits × 10 bits (signed) = WIDTH+11 bits.
    // Declare at WIDTH+11 bits to capture the full product without truncation.
    //
    // Q-format scaling:
    //   Input  has FRAC_BITS = 2 fractional bits
    //   181 constant has 8 fractional bits
    //   → product has 10 fractional bits
    //   → shift right 8  restores 2 fractional bits  ✓
    // =========================================================
    wire signed [WIDTH+10:0] mult_real_full = tw_real * $signed(10'sd181);
    wire signed [WIDTH+10:0] mult_imag_full = tw_imag * $signed(10'sd181);

    // Shift right 8: sheds the 8 twiddle fractional bits → restores input FRAC_BITS
    // Result is WIDTH+3 bits of significant data; assign to WIDTH+1 (wb wires)
    // — upper bits are sign-extension, no loss for in-range FFT values.
    wire signed [WIDTH:0] wb_real = mult_real_full >>> 8;
    wire signed [WIDTH:0] wb_imag = mult_imag_full >>> 8;

    // =========================================================
    // Step 5: Butterfly  (1-bit growth: WIDTH+1 → WIDTH+1 output)
    // =========================================================
    assign y0_real = a_real_ext + wb_real;
    assign y0_img  = a_img_ext  + wb_imag;

    assign y1_real = a_real_ext - wb_real;
    assign y1_img  = a_img_ext  - wb_imag;

endmodule
